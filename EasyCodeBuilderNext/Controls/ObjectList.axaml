<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EasyCodeBuilderNext.Controls"
             xmlns:models="clr-namespace:EasyCodeBuilderNext.Core.Models;assembly=EasyCodeBuilderNext.Core"
             xmlns:vm="clr-namespace:EasyCodeBuilderNext.ViewModels"
             x:Class="EasyCodeBuilderNext.Controls.ObjectList"
             x:DataType="controls:ObjectList"
             x:CompileBindings="False">

  <UserControl.Styles>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="#4C97FF"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#20000000"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0">
      <ListBox ItemsSource="{Binding Objects}"
               SelectedItem="{Binding SelectedObject}"
               SelectionMode="Single">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="models:CodeObject">
            <Border Padding="8,4" Margin="2" CornerRadius="4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- アイコン（継承がある場合は変形） -->
                <TextBlock Text="&#x25A1;" FontSize="14" VerticalAlignment="Center"/>

                <!-- クラス名 -->
                <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>

                <!-- 基底クラス表示 -->
                <TextBlock Text="{Binding BaseClassName, StringFormat=': {0}'}"
                           FontSize="10" Foreground="Gray"
                           IsVisible="{Binding BaseClassName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>

    <!-- 追加/削除ボタン -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4">
      <Button Content="+" Width="30" Height="30" Margin="2"
              Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).AddObjectCommand}"/>
      <Button Content="-" Width="30" Height="30" Margin="2"
              Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).RemoveObjectCommand}"/>
    </StackPanel>
  </Grid>
</UserControl>
