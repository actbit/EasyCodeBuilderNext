<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EasyCodeBuilderNext.Controls">
    <Style Selector="controls|PuzzleBlock">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="12,8"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="Transparent"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}">
                    <TextBlock Text="{Binding Block.DisplayName, RelativeSource={RelativeSource TemplatedParent}}"
                               Foreground="White"
                               FontSize="13"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
